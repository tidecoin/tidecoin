+PQCLEAN_FALCON512_CLEAN_crypto_sign_keypair_deterministic(
+    uint8_t *pk, uint8_t *sk,
+    const uint8_t *seed, size_t seed_len) {
+    if (seed_len != 48) {
+        return -1;
+    }
+    union {
+        uint8_t b[FALCON_KEYGEN_TEMP_9];
+        uint64_t dummy_u64;
+        fpr dummy_fpr;
